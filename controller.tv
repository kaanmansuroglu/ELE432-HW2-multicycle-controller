// riscv multi-cycle controller test vectors
// jbrake@hmc.edu - Updated ALU encoding
//
// ALUControl encoding (Harris):
//   000 = add    (lw/sw/fetch PC+4 dahil)
//   001 = subtract (beq, sub)
//   010 = and
//   011 = or
//   101 = slt

// Op[6:0] Funct3[2:0] Funct7b5 Zero _ ImmSrc[1:0] ALUSrcA[1:0] ALUSrcB[1:0] ResultSrc[1:0] AdrSrc ALUControl[2:0] IRWrite PCWrite RegWrite MemWrite

//op[6:0]_funct3[2:0]_funct7b5_Zero_ImmSrc[1:0]_ALUSrcA[1:0]_ALUSrcB[1:0]_ResultSrc[1:0]_AdrSrc_ALUControl[2:0]_IRWrite_PCWrite_RegWrite_MemWrite

// add (funct3=000, funct7b5=0 → ALUControl=000)
0110011_000_0_0__XX_00_10_10_0_000_1_1_0_0 // Fetch
0110011_000_0_0__XX_01_01_00_0_000_0_0_0_0 // Decode
0110011_000_0_0__XX_10_00_00_0_000_0_0_0_0 // ExecuteR
0110011_000_0_0__XX_00_00_00_0_000_0_0_1_0 // ALUWB

// sub (funct3=000, funct7b5=1 → ALUControl=001)
0110011_000_1_0__XX_00_10_10_0_000_1_1_0_0 // Fetch
0110011_000_1_0__XX_01_01_00_0_000_0_0_0_0 // Decode
0110011_000_1_0__XX_10_00_00_0_001_0_0_0_0 // ExecuteR
0110011_000_1_0__XX_00_00_00_0_000_0_0_1_0 // ALUWB

// or (funct3=110 → ALUControl=011)
0110011_110_0_0__XX_00_10_10_0_000_1_1_0_0 // Fetch
0110011_110_0_0__XX_01_01_00_0_000_0_0_0_0 // Decode
0110011_110_0_0__XX_10_00_00_0_011_0_0_0_0 // ExecuteR
0110011_110_0_0__XX_00_00_00_0_000_0_0_1_0 // ALUWB

// and (funct3=111 → ALUControl=010)
0110011_111_0_0__XX_00_10_10_0_000_1_1_0_0 // Fetch
0110011_111_0_0__XX_01_01_00_0_000_0_0_0_0 // Decode
0110011_111_0_0__XX_10_00_00_0_010_0_0_0_0 // ExecuteR
0110011_111_0_0__XX_00_00_00_0_000_0_0_1_0 // ALUWB

// slt (funct3=010 → ALUControl=101)
0110011_010_0_0__XX_00_10_10_0_000_1_1_0_0 // Fetch
0110011_010_0_0__XX_01_01_00_0_000_0_0_0_0 // Decode
0110011_010_0_0__XX_10_00_00_0_101_0_0_0_0 // ExecuteR
0110011_010_0_0__XX_00_00_00_0_000_0_0_1_0 // ALUWB

// lw (ALUOp=00 → ALUControl=000 her zaman)
0000011_010_0_0__00_00_10_10_0_000_1_1_0_0 // Fetch
0000011_010_0_0__00_01_01_00_0_000_0_0_0_0 // Decode
0000011_010_0_0__00_10_01_00_0_000_0_0_0_0 // MemAdr
0000011_010_0_0__00_00_00_00_1_000_0_0_0_0 // MemRead
0000011_010_0_0__00_00_00_01_0_000_0_0_1_0 // MemWB

// addi (funct3=000, funct7b5=0 → ALUControl=000)
0010011_000_0_0__00_00_10_10_0_000_1_1_0_0 // Fetch
0010011_000_0_0__00_01_01_00_0_000_0_0_0_0 // Decode
0010011_000_0_0__00_10_01_00_0_000_0_0_0_0 // ExecuteI
0010011_000_0_0__00_00_00_00_0_000_0_0_1_0 // ALUWB

// sw (ALUOp=00 → ALUControl=000)
0100011_010_0_0__01_00_10_10_0_000_1_1_0_0 // Fetch
0100011_010_0_0__01_01_01_00_0_000_0_0_0_0 // Decode
0100011_010_0_0__01_10_01_00_0_000_0_0_0_0 // MemAdr
0100011_010_0_0__01_00_00_00_1_000_0_0_0_1 // MemWrite

// beq (ALUOp=01 → ALUControl=001)
1100011_000_0_0__10_00_10_10_0_000_1_1_0_0 // Fetch
1100011_000_0_0__10_01_01_00_0_000_0_0_0_0 // Decode
1100011_000_0_0__10_10_00_00_0_001_0_0_0_0 // BEQ

// jal (ALUOp=00 → ALUControl=000)
1101111_000_0_0__11_00_10_10_0_000_1_1_0_0 // Fetch
1101111_000_0_0__11_01_01_00_0_000_0_0_0_0 // Decode
1101111_000_0_0__11_01_10_00_0_000_0_1_0_0 // JAL
1101111_000_0_0__11_00_00_00_0_000_0_0_1_0 // ALUWB
